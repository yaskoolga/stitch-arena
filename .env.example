# Database (PostgreSQL)
# Get from: https://neon.tech
# Format: postgresql://user:password@host/database?sslmode=require
DATABASE_URL="postgresql://user:password@your-host.neon.tech/neondb?sslmode=require"

# NextAuth Configuration
# Generate NEXTAUTH_SECRET: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="your-generated-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (Production)
# Get from: https://console.cloud.google.com
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Cloudinary (Image Storage)
# Get from: https://cloudinary.com/console
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# CV Service (Python FastAPI)
# Local: http://localhost:8001
# Production: Railway URL
CV_SERVICE_URL="http://localhost:8001"

# Admin
ADMIN_EMAIL="your-email@example.com"

# Cron Jobs (для автоматических челленджей)
# Generate random string
CRON_SECRET="your-random-cron-secret"
