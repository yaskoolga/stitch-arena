generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String                 @id @default(cuid())
  email                 String                 @unique
  name                  String?
  password              String?
  avatar                String?
  bio                   String?
  selectedTitle         String?                // ID of unlocked achievement used as title
  notificationsEnabled  Boolean                @default(true) // Toggle notifications on/off
  resetToken            String?
  resetTokenExpiry      DateTime?
  role                  String                 @default("user") // "user" | "admin"
  isBanned              Boolean                @default(false)
  bannedAt              DateTime?
  bannedReason          String?
  totalStitches         Int                    @default(0) // Cached total for leaderboards
  projectsCount         Int                    @default(0) // Cached count for leaderboards
  currentStreak         Int                    @default(0) // Current consecutive days
  longestStreak         Int                    @default(0) // Record streak
  lastActivityDate      DateTime?              // Last daily log date (for streak)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @default(now()) @updatedAt
  projects              Project[]
  achievements          UserAchievement[]
  comments              Comment[]
  likes                 Like[]
  challengeParticipants ChallengeParticipant[]
  createdChallenges     Challenge[]            @relation("CreatedChallenges")
  followers             Follow[]               @relation("UserFollowers")
  following             Follow[]               @relation("UserFollowing")
  notifications         Notification[]
  projectFollows        ProjectFollow[]        @relation("ProjectFollows")
  reportsMade           Report[]               @relation("ReportsMade")
  reportsReceived       Report[]               @relation("ReportsReceived")
  adminLogs             AdminLog[]
  badges                UserBadge[]
  leaderboardEntries    Leaderboard[]
  eventParticipants     EventParticipant[]
}

model Project {
  id              String     @id @default(cuid())
  userId          String
  title           String
  description     String?
  manufacturer    String?    // Pattern manufacturer (DMC, Dimensions, etc.)
  articleNumber   String?    // Article/SKU number of the pattern
  coverImage      String?    // Cover photo (from package) - shown in project cards
  schemaImage     String?    // Optional reference photo of pattern (technical)
  totalStitches   Int        // Total stitches in project (manual input or width × height)
  initialStitches Int        @default(0) // Already stitched before tracking (not counted in stats/challenges)
  width           Int?       // Pattern width (for auto-calculation)
  height          Int?       // Pattern height (for auto-calculation)
  canvasType      String?    // Aida 14, 16, 18, etc.
  calibrationData String?    // JSON string with calibration settings
  status          String     @default("stash") // stash, in_progress, completed, abandoned
  startedAt       DateTime?  // Date when first stitches were logged (not initial stitches)
  isPublic        Boolean    @default(false)
  themes          String?    @default("[]") // JSON array of project themes/categories
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs            DailyLog[]
  comments        Comment[]
  likes           Like[]
  followers       ProjectFollow[]        @relation("ProjectFollowers")
}

model DailyLog {
  id               String   @id @default(cuid())
  projectId        String
  date             DateTime
  photoUrl         String?  // Photo of work-in-progress
  previousPhotoUrl String?  // Previous photo for comparison
  totalStitches    Int      @default(0) // Cumulative total stitches at this point
  dailyStitches    Int      @default(0) // Increment for this day (total - previous)
  aiDetected       Int?     // AI detected count (before user correction)
  aiConfidence     Float?   // AI confidence score (0-1)
  userCorrected    Boolean  @default(false) // Did user manually correct the AI result?
  notes            String?
  createdAt        DateTime @default(now())
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, date])
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String   // Type of achievement (e.g., "first_project", "100k_stitches")
  unlockedAt    DateTime @default(now())
  progress      Int      @default(0) // Current progress towards achievement (if applicable)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
}

model Comment {
  id        String   @id @default(cuid())
  userId    String
  projectId String
  text      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([userId])
}

model Like {
  id        String   @id @default(cuid())
  userId    String
  projectId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([projectId])
}

model Challenge {
  id                String                 @id @default(cuid())
  type              String                 // "speed", "streak", "completion"
  title             String
  description       String?
  startDate         DateTime
  endDate           DateTime
  targetValue       Int                    // e.g., 10000 stitches
  isActive          Boolean                @default(true)
  isAutoGenerated   Boolean                @default(false)
  createdBy         String?                // User who created this challenge (null for auto-generated)
  eventId           String?                // Optional link to event
  createdAt         DateTime               @default(now())
  creator           User?                  @relation("CreatedChallenges", fields: [createdBy], references: [id], onDelete: SetNull)
  event             Event?                 @relation("EventChallenges", fields: [eventId], references: [id], onDelete: SetNull)
  participants      ChallengeParticipant[]
  leaderboard       ChallengeLeaderboard[]

  @@index([isActive, startDate, endDate])
  @@index([createdBy, isActive])
  @@index([eventId])
}

model ChallengeParticipant {
  id              String    @id @default(cuid())
  challengeId     String
  userId          String
  joinedAt        DateTime  @default(now())
  currentProgress Int       @default(0)
  lastUpdated     DateTime  @default(now())
  challenge       Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([challengeId, userId])
  @@index([userId])
  @@index([challengeId])
}

model ChallengeLeaderboard {
  id          String    @id @default(cuid())
  challengeId String
  userId      String
  rank        Int
  score       Int
  updatedAt   DateTime  @updatedAt
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([challengeId, userId])
  @@index([challengeId, rank])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String   // User who is following
  followingId String   // User being followed
  createdAt   DateTime @default(now())
  follower    User     @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Notification {
  id         String   @id @default(cuid())
  userId     String   // Recipient of the notification
  type       String   // "like", "comment", "follow", "achievement", "projectfollow"
  actorId    String?  // User who performed the action (nullable for system notifications)
  resourceId String?  // ID of related resource (projectId, commentId, etc.)
  content    String   // Notification message
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
}

model ProjectFollow {
  id        String   @id @default(cuid())
  userId    String
  projectId String
  createdAt DateTime @default(now())
  user      User     @relation("ProjectFollows", fields: [userId], references: [id], onDelete: Cascade)
  project   Project  @relation("ProjectFollowers", fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([projectId])
  @@index([userId])
}

model Report {
  id             String   @id @default(cuid())
  type           String   // "comment" | "project" | "user" | "dailyLog"
  reason         String   // "spam" | "inappropriate" | "harassment" | "other"
  description    String?
  status         String   @default("pending") // "pending" | "reviewed" | "resolved" | "dismissed"
  reporterId     String
  reporter       User     @relation("ReportsMade", fields: [reporterId], references: [id], onDelete: Cascade)
  reportedUserId String?
  reportedUser   User?    @relation("ReportsReceived", fields: [reportedUserId], references: [id], onDelete: SetNull)
  resourceId     String?  // ID проекта/комментария/лога
  resolvedBy     String?
  resolvedAt     DateTime?
  adminNote      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status, createdAt])
  @@index([reporterId])
  @@index([reportedUserId])
}

model AdminLog {
  id         String   @id @default(cuid())
  adminId    String
  admin      User     @relation(fields: [adminId], references: [id], onDelete: Cascade)
  action     String   // "ban_user" | "delete_comment" | "delete_project" | "resolve_report"
  targetType String   // "user" | "project" | "comment" | "challenge" | "report"
  targetId   String
  metadata   String?  // JSON с деталями
  createdAt  DateTime @default(now())

  @@index([adminId, createdAt])
  @@index([action, createdAt])
}

model Badge {
  id          String      @id @default(cuid())
  key         String      @unique // "speed_demon", "top_contributor", "early_adopter", etc.
  category    String      // "achievement" | "event" | "special" | "challenge"
  name        String
  description String
  icon        String      // Emoji or icon identifier
  rarity      String      @default("common") // "common" | "rare" | "epic" | "legendary"
  criteria    String?     // JSON describing how to earn
  createdAt   DateTime    @default(now())
  userBadges  UserBadge[]

  @@index([category])
}

model UserBadge {
  id         String   @id @default(cuid())
  userId     String
  badgeKey   String
  earnedAt   DateTime @default(now())
  isFeatured Boolean  @default(false)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge      Badge    @relation(fields: [badgeKey], references: [key], onDelete: Cascade)

  @@unique([userId, badgeKey])
  @@index([userId])
  @@index([badgeKey])
}

model Leaderboard {
  id        String   @id @default(cuid())
  type      String   // "alltime" | "monthly" | "weekly" | "projects" | "streak"
  period    String?  // "2026-03" for monthly, "2026-W09" for weekly, null for alltime
  rank      Int
  userId    String
  score     Int      // stitches or count depending on type
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([type, period, userId])
  @@index([type, period, rank])
  @@index([userId])
}

model Event {
  id           String             @id @default(cuid())
  title        String
  description  String?
  theme        String             // "halloween", "christmas", "spring", etc.
  startDate    DateTime
  endDate      DateTime
  isActive     Boolean            @default(true)
  rewardBadge  String?            // Badge key for participants/winners
  createdAt    DateTime           @default(now())
  challenges   Challenge[]        @relation("EventChallenges")
  participants EventParticipant[]

  @@index([isActive, startDate, endDate])
}

model EventParticipant {
  id       String   @id @default(cuid())
  eventId  String
  userId   String
  joinedAt DateTime @default(now())
  score    Int      @default(0)
  event    Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}
